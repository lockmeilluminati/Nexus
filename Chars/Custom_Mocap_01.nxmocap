[NexusMoCap]
FPS=30
Skin=4
Pos=0,0,0
Rot=0,0,0
Scale=1
Snap=1
[CustomMathCode]
// === ADVANCED PROCEDURAL MATH CHARACTER ===
Color myColor = { 0, 255, 120, 255 };
Color fillMode = { 10, 40, 60, 200 };

// 1. Calculate Core Body Vectors
Vector3 shoulderMid = Vector3Scale(Vector3Add(frame.joints[0], frame.joints[1]), 0.5f);
Vector3 hipMid = Vector3Scale(Vector3Add(frame.joints[6], frame.joints[7]), 0.5f);
Vector3 spineDir = Vector3Normalize(Vector3Subtract(shoulderMid, hipMid));
Vector3 shoulderVec = Vector3Normalize(Vector3Subtract(frame.joints[1], frame.joints[0]));
Vector3 forward = Vector3Normalize(Vector3CrossProduct(shoulderVec, spineDir));

// 2. Draw Cranium
Vector3 headCenter = Vector3Add(frame.joints[12], Vector3Scale(forward, -0.08f));
DrawSphere(headCenter, 0.09f, fillMode);
DrawSphereWires(headCenter, 0.09f, 8, 8, myColor);

// 3. Draw Procedural Ribcage
for (int i = 0; i <= 6; i++) {
    float lerp = (float)i / 6.0f;
    Vector3 spinePt = Vector3Lerp(shoulderMid, hipMid, lerp);
    float w = sinf(lerp * PI) * 0.15f;
    float d = sinf(lerp * PI) * 0.1f;
    Vector3 lEdge = Vector3Add(spinePt, Vector3Scale(shoulderVec, -w));
    Vector3 rEdge = Vector3Add(spinePt, Vector3Scale(shoulderVec, w));
    Vector3 sternum = Vector3Add(spinePt, Vector3Scale(forward, d));
    DrawLine3D(lEdge, sternum, myColor);
    DrawLine3D(rEdge, sternum, myColor);
}

[EndCode]
